# Tenant-scoped application role. `pnpm --filter @appkit/playground seed`
# creates this role with password `appkit` and installs the RLS policies.
APPKIT_DB_URL=postgresql://appkit_app:appkit@127.0.0.1:5599/appkit

# Postgres owner/superuser used only for schema setup, seeding, and platform
# operations that intentionally cross tenant boundaries. Adapt to your local DB.
APPKIT_SUPER_URL=postgresql://postgres:postgres@127.0.0.1:5599/appkit

# Local-only example. Generate independent 32+ character secrets in production.
APPKIT_SESSION_SECRET=appkit-local-session-secret-change-me
APPKIT_SECRET=appkit-local-sealing-secret-change-me
