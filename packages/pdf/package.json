{
  "name": "@appkit/pdf",
  "version": "0.1.1",
  "description": "Pure-JS documents, statements, templates, and hardened HTML-to-PDF rendering.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./html": "./src/html.ts",
    "./template": "./src/template.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/tokens": "workspace:*",
    "pdfkit": "^0.17.1"
  },
  "peerDependencies": {
    "isomorphic-dompurify": "^3.18.0",
    "puppeteer-core": "^25.3.0"
  },
  "peerDependenciesMeta": {
    "isomorphic-dompurify": {
      "optional": true
    },
    "puppeteer-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/pdfkit": "^0.13.9",
    "isomorphic-dompurify": "^3.18.0",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^25.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/pdf"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/pdf#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
