{
  "name": "@appkit/dashboard",
  "version": "0.1.0",
  "description": "Optional dashboard layouts, insight cards, visual studio, and feature-owned persistence.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
