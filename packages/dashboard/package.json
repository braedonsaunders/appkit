      "optional": true
    },
    "@appkit/ui": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "react-grid-layout": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appkit/db": "workspace:*",
    "@appkit/ui": "workspace:*",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-orm": "^0.45.2",
    "drizzle-kit": "^0.30.6",
    "lucide-react": "^1.24.0",
    "react": "^19",
    "react-dom": "^19",
    "react-grid-layout": "^2.2.3",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
