{
  "name": "@appkit/forms-core",
  "version": "0.1.0",
  "description": "Framework-neutral form schemas, evaluation, validation, scoring, localization, and automation planning.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./automation": "./src/automation.ts",
    "./safety-automation": "./src/automation.ts",
    "./safety-flow-subjects": "./src/flow-subjects.ts",
    "./business-automation": "./src/business-automation.ts",
    "./business-flow-subjects": "./src/business-flow-subjects.ts",
    "./response-normalize": "./src/response-normalize.ts",
    "./sanitize": "./src/sanitize.ts",
    "./text": "./src/text.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude src/business-automation.test.ts && node --import tsx --test src/business-automation.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/i18n": "workspace:*",
    "htmlparser2": "^10.1.0",
    "isomorphic-dompurify": "^3.18.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@appkit/email-render": "workspace:*",
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/forms-core"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/forms-core#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
