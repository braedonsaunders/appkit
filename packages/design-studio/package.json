{
  "name": "@appkit/design-studio",
  "version": "0.1.0",
  "description": "Generalized print-design document schema and renderer extracted from BeaconHS.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./fabric": "./src/fabric.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/tokens": "workspace:*"
  },
  "peerDependencies": {
    "fabric": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "fabric": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "fabric": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/design-studio"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/design-studio#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
