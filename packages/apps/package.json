{
  "name": "@appkit/apps",
  "version": "1.0.0",
  "description": "Installable application bundles with immutable versions, governed QuickJS backends, opaque-origin frontends, capabilities, authoring, and distribution.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest.ts",
    "./bundle": "./src/bundle.ts",
    "./bridge": "./src/bridge.ts",
    "./runtime": "./src/runtime.ts",
    "./service": "./src/service.ts",
    "./schema": "./src/schema.ts",
    "./drizzle": "./src/drizzle.ts",
    "./memory": "./src/memory.ts",
    "./react": "./src/react.ts",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "drizzle"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@appkit/endpoints": "workspace:*",
    "@uiw/react-codemirror": "^4.25.11",
    "fflate": "^0.8.2",
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "@appkit/db": "^0.2.0",
    "@appkit/ui": "^0.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@appkit/db": {
      "optional": true
    },
    "@appkit/ui": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appkit/db": "workspace:*",
    "@appkit/ui": "workspace:*",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.24.0",
    "react": "^19",
    "react-dom": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/apps"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/apps#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "applications",
    "extensions",
    "quickjs",
    "sandbox"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
