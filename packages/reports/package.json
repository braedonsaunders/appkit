{
  "name": "@appkit/reports",
  "version": "0.1.0",
  "description": "Composable saved-report, scheduling, execution, and document-rendering contracts.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./document": "./src/document-entry.ts",
    "./react": "./src/react.ts",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/analytics": "workspace:*"
  },
  "peerDependencies": {
    "@appkit/ui": "^0.1.0",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@appkit/ui": { "optional": true },
    "lucide-react": { "optional": true },
    "react": { "optional": true }
  },
  "devDependencies": {
    "@appkit/ui": "workspace:*",
    "@types/node": "^22",
    "@types/react": "^19",
    "lucide-react": "^1.24.0",
    "react": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/reports"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/reports#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
