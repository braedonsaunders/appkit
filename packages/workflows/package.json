{
  "name": "@appkit/workflows",
  "version": "1.0.0",
  "description": "Durable workflow graphs, replay-safe actions, approval gates, and optional React and Drizzle adapters.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./approval-tokens": "./src/approval-tokens.ts",
    "./schema": "./src/schema.ts",
    "./drizzle": "./src/drizzle.ts",
    "./react": "./src/react.ts",
    "./approval-react": "./src/approval-react.ts",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "drizzle"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@appkit/forms": "^0.2.0",
    "@appkit/forms-core": "^0.1.1",
    "@appkit/ui": "^0.1.1",
    "@appkit/db": "^0.2.0",
    "drizzle-orm": "^0.45.2",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@appkit/forms": {
      "optional": true
    },
    "@appkit/forms-core": {
      "optional": true
    },
    "@appkit/ui": {
      "optional": true
    },
    "@appkit/db": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "@xyflow/react": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appkit/forms": "workspace:*",
    "@appkit/forms-core": "workspace:*",
    "@appkit/ui": "workspace:*",
    "@appkit/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^1.24.0",
    "react": "^19",
    "react-dom": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/workflows"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/workflows#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
