{
  "name": "@appkit/workflows",
  "version": "0.1.0",
  "description": "Dependency-free workflow graphs with an optional source-faithful React Flow builder.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": ["*.css"],
  "exports": {
    ".": "./src/index.ts",
    "./react": "./src/react.ts",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@appkit/ui": "^0.1.0",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@appkit/ui": { "optional": true },
    "@xyflow/react": { "optional": true },
    "lucide-react": { "optional": true },
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "devDependencies": {
    "@appkit/ui": "workspace:*",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@xyflow/react": "^12.10.0",
    "lucide-react": "^1.24.0",
    "react": "^19",
    "react-dom": "^19",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
