{
  "name": "@appkit/tokens",
  "version": "0.1.0",
  "description": "The design foundation — semantic color, radius, elevation, and motion tokens. Light/dark. Tailwind v4, CSS-first.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": ["*.css"],
  "exports": {
    ".": "./src/index.ts",
    "./tokens.css": "./src/tokens.css",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  }
}
