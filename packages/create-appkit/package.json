{
  "name": "create-appkit",
  "version": "0.1.1",
  "description": "Create a production-ready Next.js application on the modular AppKit foundation.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "create-appkit": "./dist/index.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "exports": {
    ".": "./src/scaffold.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/create-appkit"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/create-appkit#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
