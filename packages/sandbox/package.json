{
  "name": "@appkit/sandbox",
  "version": "0.1.0",
  "description": "Governed QuickJS isolation for user-authored JavaScript with async host capabilities, execution budgets, and structured faults.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src"],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "quickjs-emscripten": "^0.31.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/sandbox"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/sandbox#readme",
  "bugs": { "url": "https://github.com/braedonsaunders/appkit/issues" },
  "engines": { "node": ">=22" },
  "keywords": ["appkit", "quickjs", "sandbox", "user-code"],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
