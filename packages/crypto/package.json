{
  "name": "@appkit/crypto",
  "version": "0.2.0",
  "description": "Sealed secrets (AES-256-GCM, HKDF-derived key) — the single implementation for tenant credentials at rest.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.2"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/crypto"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/crypto#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
