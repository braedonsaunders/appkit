{
  "name": "@appkit/forms",
  "version": "0.2.0",
  "description": "Production form designer, workflow authoring bridge, and complete fill runtime for AppKit applications.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./src/styles.css",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/editor": "workspace:*",
    "@appkit/forms-core": "workspace:*",
    "@appkit/i18n": "workspace:*",
    "@appkit/tokens": "workspace:*",
    "@appkit/ui": "workspace:*",
    "@excalidraw/excalidraw": "^0.18.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.24.0",
    "react-grid-layout": "^2.2.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "react": "^19",
    "react-dom": "^19",
    "tsx": "^4.19.2"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/forms"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/forms#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
