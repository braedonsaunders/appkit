{
  "name": "@appkit/sync",
  "version": "1.0.0",
  "description": "Production data synchronization with transactional batches, per-record ledgers, fail-closed snapshots, connector families, and durable cursors.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./catalog": "./src/types.ts",
    "./registry": "./src/registry.ts",
    "./csv": "./src/csv.ts",
    "./transform": "./src/transform.ts",
    "./connectors/csv": "./src/connectors/csv.ts",
    "./connectors/database": "./src/connectors/database.ts",
    "./connectors/http-json": "./src/connectors/http-json.ts",
    "./connectors/nango": "./src/connectors/nango.ts",
    "./connectors/netsuite": "./src/connectors/netsuite.ts",
    "./egress": "./src/egress.ts",
    "./runtime": "./src/runtime.ts",
    "./snapshot-policy": "./src/snapshot-policy.ts",
    "./person-sync-policy": "./src/person-sync-policy.ts",
    "./db-drivers": "./src/db-drivers.ts",
    "./schema": "./src/schema.ts",
    "./drizzle": "./src/drizzle.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "drizzle"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@appkit/db": "^0.2.0",
    "drizzle-orm": "^0.45.2",
    "mssql": "^11.0.1",
    "mysql2": "^3.22.6",
    "postgres": "^3.4.9"
  },
  "peerDependenciesMeta": {
    "@appkit/db": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "mssql": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appkit/db": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "@types/node": "^22",
    "mssql": "^11.0.1",
    "mysql2": "^3.22.6",
    "postgres": "^3.4.9",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/sync"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/sync#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
