{
  "name": "@appkit/jobs",
  "version": "0.1.0",
  "description": "Production BullMQ runtime with lazy connections, notification queue profiles, readiness, validation, rate limits, and Web Push.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./health": "./src/health.ts",
    "./rate-limit": "./src/rate-limit.ts",
    "./notifications": "./src/notifications.ts",
    "./web-push": "./src/web-push.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/sync": "workspace:*",
    "bullmq": "^5.34.0",
    "ioredis": "^5.4.2",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/jobs"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/jobs#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
