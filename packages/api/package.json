{
  "name": "@appkit/api",
  "version": "0.1.0",
  "description": "Public REST API toolkit — API-key auth, idempotent writes, typed errors, and a request wrapper. Framework-neutral.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": ["src"],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/db": "workspace:*",
    "@appkit/tenant": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4.19.2"
  }
}
