{
  "name": "@appkit/forms-pdf",
  "version": "0.1.0",
  "description": "Composable form-summary HTML with optional PDF, template, and design-document adapters.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./summary": "./src/summary.ts",
    "./template": "./src/template.ts",
    "./design": "./src/design.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@appkit/design-studio": "^0.1.0",
    "@appkit/pdf": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "@appkit/design-studio": {
      "optional": true
    },
    "@appkit/pdf": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appkit/design-studio": "workspace:*",
    "@appkit/pdf": "workspace:*",
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/forms-pdf"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/forms-pdf#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
