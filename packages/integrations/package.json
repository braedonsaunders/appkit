  },
  "peerDependenciesMeta": {
    "@appkit/email-render": {
      "optional": true
    },
    "@appkit/db": {
      "optional": true
    },
    "@appkit/sync": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appkit/email-render": "workspace:*",
    "@appkit/db": "workspace:*",
    "@appkit/sync": "workspace:*",
    "drizzle-orm": "^0.45.2",
