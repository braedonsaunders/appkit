{
  "name": "@appkit/integrations",
  "version": "0.1.0",
  "description": "Trigger-to-destination automation with durable delivery ledgers and optional HTTP, chat, Sheets, email, and SQL adapters.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./catalog": "./src/types.ts",
    "./destination-catalog": "./src/destination-catalog.ts",
    "./http": "./src/http.ts",
    "./chat": "./src/chat.ts",
    "./sheets": "./src/sheets.ts",
    "./email": "./src/email.ts",
    "./sql": "./src/sql.ts",
    "./sql-catalog": "./src/sql-catalog.ts",
    "./schema": "./src/schema.ts",
    "./drizzle": "./src/drizzle.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src",
    "drizzle"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "@appkit/email-render": "^0.1.0",
    "@appkit/db": "^0.1.0",
    "@appkit/sync": "^0.1.0",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependenciesMeta": {
    "@appkit/email-render": {
      "optional": true
    },
    "@appkit/db": {
      "optional": true
    },
    "@appkit/sync": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appkit/email-render": "workspace:*",
    "@appkit/db": "workspace:*",
    "@appkit/sync": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "@types/node": "^22",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/integrations"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/integrations#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
