{
  "name": "@appkit/forms-documents",
  "version": "0.1.1",
  "description": "Optional form document styles and generated PDF templates over the shared companion-field contract.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./package.json": "./package.json"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "node ../../scripts/build-package.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@appkit/forms-core": "workspace:*",
    "@appkit/i18n": "workspace:*",
    "@appkit/tokens": "workspace:*"
  },
  "devDependencies": {
    "@appkit/email-render": "workspace:*",
    "@types/node": "^22",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  },
  "author": "Braedon Saunders",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/braedonsaunders/appkit.git",
    "directory": "packages/forms-documents"
  },
  "homepage": "https://github.com/braedonsaunders/appkit/tree/main/packages/forms-documents#readme",
  "bugs": {
    "url": "https://github.com/braedonsaunders/appkit/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "appkit",
    "application-framework",
    "typescript"
  ],
  "publishConfig": {
    "access": "public",
    "directory": "dist",
    "linkDirectory": false,
    "provenance": true
  }
}
